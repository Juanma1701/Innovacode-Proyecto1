<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registrar Salida"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvNombreSalida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF6B6B"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvStockActual"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#A0A8C0"
        android:textSize="13sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:text="Cantidad a retirar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#A0A8C0"
        android:textSize="13sp"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etCantidadSalida"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej. 5"
        android:inputType="number"
        android:textColor="#FFFFFF"
        android:textColorHint="#6B7280"
        android:backgroundTint="#FF6B6B"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnConfirmarSalida"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirmar Salida"
        android:backgroundTint="#FF6B6B"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnCancelarSalida"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancelar"
        android:backgroundTint="#2A2A3E"
        android:textColor="#FFFFFF"
        android:layout_marginTop="12dp"/>

</LinearLayout>