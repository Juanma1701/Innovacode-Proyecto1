<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F"
    android:gravity="center"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <!-- ══ Logo ══ -->
    <LinearLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/fondo_logo"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_candado"
            android:contentDescription="Logo app"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- ══ Título ══ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bienvenido de nuevo"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inicia sesión para continuar"
        android:textColor="#6B7280"
        android:textSize="13sp"
        android:layout_marginBottom="24dp" />

    <!-- ══ Tarjeta del formulario ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/fondo_tarjeta"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:elevation="8dp">

        <!-- ── Label: Correo ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CORREO ELECTRÓNICO"
            android:textColor="#A0A8C0"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.10"
            android:layout_marginBottom="6dp" />

        <!-- ── Campo: Correo ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/fondo_campo_dark"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_correo"
                android:contentDescription="Ícono correo"
                app:tint="#6C63FF"
                android:layout_marginEnd="10dp" />

            <EditText
                android:id="@+id/etCorreo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="tucorreo@ejemplo.com"
                android:textColorHint="#3D3D5C"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:inputType="textEmailAddress"
                android:background="@null"
                android:singleLine="true"
                android:imeOptions="actionNext"
                android:autofillHints="emailAddress" />
        </LinearLayout>

        <!-- ── Label: Contraseña ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTRASEÑA"
            android:textColor="#A0A8C0"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.10"
            android:layout_marginBottom="6dp" />

        <!-- ── Campo: Contraseña ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/fondo_campo_dark"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="4dp"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_candado"
                android:contentDescription="Ícono candado"
                app:tint="#6C63FF"
                android:layout_marginEnd="10dp" />

            <EditText
                android:id="@+id/etContrasena"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="••••••••"
                android:textColorHint="#3D3D5C"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:inputType="textPassword"
                android:background="@null"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:autofillHints="password" />

            <ImageButton
                android:id="@+id/btnVerContrasena"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_ojo_cerrado"
                android:contentDescription="Ver contraseña"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#6C63FF"
                android:padding="10dp" />
        </LinearLayout>

        <!-- ── ¿Olvidaste tu contraseña? ── -->
        <TextView
            android:id="@+id/tvOlvideContrasena"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Olvidaste tu contraseña?"
            android:textColor="#6C63FF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_gravity="end"
            android:layout_marginBottom="20dp" />

        <!-- ── Botón: Iniciar Sesión ── -->
        <Button
            android:id="@+id/btnIniciarSesion"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Iniciar Sesión"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:background="@drawable/fondo_boton_violeta"
            android:stateListAnimator="@null"
            android:layout_marginBottom="12dp" />

        <!-- ── Divisor ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#1E1E35" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  o continúa con  "
                android:textColor="#3D3D5C"
                android:textSize="11sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#1E1E35" />
        </LinearLayout>

        <!-- ── Botón: Google ── -->
        <Button
            android:id="@+id/btnGoogle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Continuar con Google"
            android:textColor="#A0A8C0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/fondo_boton_outline"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- ══ ¿No tienes cuenta? Crear cuenta ══ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿No tienes cuenta?  "
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvCrearCuenta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crear cuenta"
            android:textColor="#6C63FF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/fondo_etiqueta_acento"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </LinearLayout>

</LinearLayout>