<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".Dashboard.Content.Dashboard">

    <LinearLayout
        android:layout_width="409dp"
        android:layout_height="729dp"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp"
        android:gravity="center" >


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="right">

                    <Button
                        android:id="@+id/btnRedondo"
                        android:layout_width="70dp"
                        android:drawableTop="@drawable/ic_persona"
                        android:layout_height="70dp"
                        android:background="@drawable/boton_personalizado_perfil"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/imageView2"
                    android:layout_width="80dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    app:srcCompat="@drawable/ic_logo_innovacode" />

                <TextView
                    android:id="@+id/textView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INNOVACODE"
                    android:textColor="#29ABE2"
                    android:textSize="30dp"
                    android:textStyle="bold"
                    android:gravity="top"/>

            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="204dp"
                android:layout_height="50dp"
                android:backgroundTint="@color/white"
                android:gravity="center">

                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Compras: "
                    android:textSize="30dp"
                    android:textColor="@color/white"
                    android:gravity="center"/>

            </LinearLayout>
            <LinearLayout
                android:layout_width="204dp"
                android:layout_height="50dp"
                android:backgroundTint="@color/white"
                android:gravity="center">

                <TextView
                    android:id="@+id/textView3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ventas: "
                    android:textSize="30dp"
                    android:textColor="@color/white"
                    android:gravity="center"/>
            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="209dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btninvent"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_margin="10dp"
                android:text="Inventario"
                android:background="@drawable/boton_personalizado"
                android:drawableTop="@drawable/ic_inventario"
                android:drawablePadding="8dp"
                android:paddingTop="20dp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16dp" />

            <Button
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_margin="10dp"
                android:drawableTop="@drawable/ic_reportes"
                android:background="@drawable/boton_personalizado"
                android:paddingTop="20dp"
                android:text="Reportes"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="209dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_margin="10dp"
                android:drawableTop="@drawable/ic_compras"
                android:background="@drawable/boton_personalizado"
                android:paddingTop="20dp"
                android:text="Compras"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:textStyle="bold"/>

            <Button
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_margin="10dp"
                android:drawableTop="@drawable/ic_ventas"
                android:background="@drawable/boton_personalizado"
                android:paddingTop="20dp"
                android:text="Ventas"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>