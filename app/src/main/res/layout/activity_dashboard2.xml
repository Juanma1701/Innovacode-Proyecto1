<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827"
    tools:context=".Dashboard.Content.Dashboard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="right">

                    <ImageButton
                        android:id="@+id/btnperfil"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_persona"
                        android:scaleType="fitCenter"
                        android:padding="14dp"
                        android:background="@drawable/fondo_persona_perfil"
                        android:tint="@color/white"
                        android:pointerIcon="hand"/>

                </LinearLayout>

                <ImageView
                    android:id="@+id/imageView2"
                    android:layout_width="80dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    app:srcCompat="@drawable/ic_logo_innovacode" />

                <TextView
                    android:id="@+id/titulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NovaCore"
                    android:textColor="#29ABE2"
                    android:textSize="30dp"
                    android:textStyle="bold"
                    android:gravity="top"/>

            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardAlertas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvResumenAlertas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FF6B6B"
                    android:textSize="16sp"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="209dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btninvent"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_margin="10dp"
                android:text="Inventario"
                android:background="@drawable/boton_personalizado"
                android:drawableTop="@drawable/ic_inventario"
                android:drawablePadding="8dp"
                android:paddingTop="20dp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:pointerIcon="hand"/>

            <Button
                android:id="@+id/btnreportes"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_margin="10dp"
                android:drawableTop="@drawable/ic_reportes"
                android:background="@drawable/boton_personalizado"
                android:paddingTop="20dp"
                android:text="Reportes"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:textStyle="bold"
                android:pointerIcon="hand"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="209dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btncompras"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_margin="10dp"
                android:drawableTop="@drawable/ic_compras"
                android:background="@drawable/boton_personalizado"
                android:paddingTop="20dp"
                android:text="Compras"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:textStyle="bold"
                android:pointerIcon="hand"/>

            <Button
                android:id="@+id/btnventas"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_margin="10dp"
                android:drawableTop="@drawable/ic_ventas"
                android:background="@drawable/boton_personalizado"
                android:paddingTop="20dp"
                android:text="Ventas"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:textStyle="bold"
                android:pointerIcon="hand"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>