<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#111827"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registrar Entrada"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvNombreProducto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#6C63FF"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:text="Cantidad a ingresar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#A0A8C0"
        android:textSize="13sp"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etCantidadEntrada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej. 10"
        android:inputType="number"
        android:textColor="#FFFFFF"
        android:textColorHint="#6B7280"
        android:backgroundTint="#6C63FF"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:text="Precio unitario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#A0A8C0"
        android:textSize="13sp"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etPrecioEntrada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej. 25000"
        android:inputType="numberDecimal"
        android:textColor="#FFFFFF"
        android:textColorHint="#6B7280"
        android:backgroundTint="#6C63FF"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnConfirmarEntrada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirmar Entrada"
        android:backgroundTint="#6C63FF"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnCancelarEntrada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancelar"
        android:backgroundTint="#2A2A3E"
        android:textColor="#FFFFFF"
        android:layout_marginTop="12dp"/>

</LinearLayout>